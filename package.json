{
  "name": "jungle-dev-kit",
  "displayName": "Annotation",
  "description": "코드 주석 태그로 팀 협업 — @todo, @bookmark, @review, @warn, @breakpoint, @note, @region 태그를 사이드바에서 관리하고, git diff에서 자동 제외",
  "version": "0.25.5",
  "publisher": "woonyong",
  "license": "MIT",
  "icon": "resources/icon.png",
  "galleryBanner": {
    "color": "#1E1E2E",
    "theme": "dark"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/woonyong-kr/jungle-dev-kit"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Linters",
    "SCM Providers",
    "Other"
  ],
  "keywords": [
    "annotation",
    "todo",
    "bookmark",
    "tag",
    "comment",
    "pintos",
    "code-review",
    "git"
  ],
  "activationEvents": [
    "workspaceContains:**/Makefile.build",
    "workspaceContains:**/Makefile",
    "workspaceContains:**/*.c",
    "workspaceContains:**/*.h",
    "workspaceContains:.annotation/config.json",
    "onCommand:jungleKit.init"
  ],
  "main": "./out/extension.js",
  "extensionKind": [
    "workspace"
  ],
  "contributes": {
    "commands": [
      {
        "command": "jungleKit.init",
        "title": "프로젝트 초기화"
      },
      {
        "command": "jungleKit.validateEnv",
        "title": "환경 검증"
      },
      {
        "command": "jungleKit.styleCheck",
        "title": "코딩 스타일 검사"
      },
      {
        "command": "jungleKit.addTodo",
        "title": "TODO 추가"
      },
      {
        "command": "jungleKit.addBookmark",
        "title": "북마크 추가"
      },
      {
        "command": "jungleKit.addReviewPoint",
        "title": "리뷰 추가"
      },
      {
        "command": "jungleKit.addWarning",
        "title": "경고 추가"
      },
      {
        "command": "jungleKit.addBreakpoint",
        "title": "브레이크포인트 추가"
      },
      {
        "command": "jungleKit.pullAndPush",
        "title": "Pull & Push"
      },
      {
        "command": "jungleKit.generateCommitMessage",
        "title": "커밋 메시지 생성"
      },
      {
        "command": "jungleKit.createPR",
        "title": "PR 만들기"
      },
      {
        "command": "jungleKit.setApiKey",
        "title": "OpenAI API 키 등록"
      },
      {
        "command": "jungleKit.removeApiKey",
        "title": "OpenAI API 키 삭제"
      },
      {
        "command": "jungleKit.undoLastCommit",
        "title": "마지막 커밋 되돌리기"
      },
      {
        "command": "jungleKit.setGoal",
        "title": "Goal 설정"
      },
      {
        "command": "jungleKit.showGoal",
        "title": "Goal 보기"
      },
      {
        "command": "jungleKit.completeGoal",
        "title": "Goal 완료 처리"
      },
      {
        "command": "jungleKit.clearGoal",
        "title": "Goal 삭제"
      },
      {
        "command": "jungleKit.resolveTagInline",
        "title": "삭제",
        "icon": "$(close)"
      },
      {
        "command": "jungleKit.addTagAtCursor",
        "title": "태그 추가",
        "icon": "$(add)"
      },
      {
        "command": "jungleKit.refreshTags",
        "title": "태그 새로고침",
        "icon": "$(refresh)"
      },
      {
        "command": "jungleKit.toggleTagView",
        "title": "보기 전환",
        "icon": "$(list-tree)"
      },
      {
        "command": "jungleKit.clearAllTags",
        "title": "모든 태그 삭제",
        "icon": "$(clear-all)"
      },
      {
        "command": "jungleKit.clearFileTags",
        "title": "파일 태그 삭제",
        "icon": "$(clear-all)"
      },
      {
        "command": "jungleKit.editTag",
        "title": "수정",
        "icon": "$(edit)"
      },
      {
        "command": "jungleKit.collapseTags",
        "title": "모두 접기",
        "icon": "$(collapse-all)"
      },
      {
        "command": "jungleKit.searchTags",
        "title": "태그 검색",
        "icon": "$(search)"
      },
      {
        "command": "jungleKit.goToTag",
        "title": "태그로 이동"
      },
      {
        "command": "jungleKit.nextTag",
        "title": "다음 태그로 이동",
        "icon": "$(arrow-down)"
      },
      {
        "command": "jungleKit.prevTag",
        "title": "이전 태그로 이동",
        "icon": "$(arrow-up)"
      },
      {
        "command": "jungleKit.configureShortcuts",
        "title": "단축키 설정",
        "icon": "$(keyboard)"
      },
      {
        "command": "jungleKit.checkReviews",
        "title": "리뷰 확인",
        "icon": "$(checklist)"
      },
      {
        "command": "jungleKit.nextTagGlobal",
        "title": "다음 태그로 이동 (전체)"
      },
      {
        "command": "jungleKit.prevTagGlobal",
        "title": "이전 태그로 이동 (전체)"
      },
      {
        "command": "jungleKit.deleteAnnotationAtCursor",
        "title": "현재 줄 태그 삭제",
        "icon": "$(trash)"
      }
    ],
    "keybindings": [
      {
        "command": "jungleKit.nextTag",
        "key": "alt+]",
        "mac": "alt+]",
        "when": "editorTextFocus"
      },
      {
        "command": "jungleKit.prevTag",
        "key": "alt+[",
        "mac": "alt+[",
        "when": "editorTextFocus"
      },
      {
        "command": "jungleKit.nextTagGlobal",
        "key": "alt+]",
        "mac": "alt+]",
        "when": "focusedView == jungleKit.tags"
      },
      {
        "command": "jungleKit.prevTagGlobal",
        "key": "alt+[",
        "mac": "alt+[",
        "when": "focusedView == jungleKit.tags"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "jungleKit",
          "title": "Annotation",
          "icon": "resources/icon.svg"
        }
      ]
    },
    "views": {
      "jungleKit": [
        {
          "id": "jungleKit.tags",
          "name": "Explorer"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "jungleKit.tags",
        "contents": "등록된 어노테이션이 없습니다.\n\n코드에 태그 주석을 작성하면 자동으로 수집됩니다.\n\n`@todo` — 구현 예정 항목\n`@bookmark` — 핵심 로직 위치 표시\n`@review` — 코드 리뷰 포인트\n`@warn` — 런타임 에러 기록\n`@breakpoint` — 디버그 중단점 + 조사식 자동 등록\n`@note` — 개인 메모 (사이드바 미표시)\n`@region`/`@endregion` — 코드 접기 영역\n\n[태그 추가](command:jungleKit.addTagAtCursor)\n\n모든 태그는 git diff에서 자동 제외됩니다."
      }
    ],
    "configuration": {
      "title": "Annotation",
      "properties": {
        "jungleKit.style.autoCreateClangFormat": {
          "type": "boolean",
          "default": true,
          "description": "Auto-create .clang-format in the workspace root if missing"
        },
        "jungleKit.sync.intervalMinutes": {
          "type": "number",
          "default": 5,
          "description": "Background fetch interval in minutes (Shadow Diff)"
        },
        "jungleKit.ai.model": {
          "type": "string",
          "default": "gpt-4o-mini",
          "enum": [
            "gpt-4o",
            "gpt-4o-mini"
          ],
          "description": "OpenAI model for AI features"
        },
        "jungleKit.goal.showStatusBar": {
          "type": "boolean",
          "default": true,
          "description": "Show the active Goal in the status bar"
        },
        "jungleKit.goal.includeInAI": {
          "type": "boolean",
          "default": true,
          "description": "Include the active Goal in AI commit, PR, and review prompts"
        }
      }
    },
    "submenus": [
      {
        "id": "jungleKit.submenu",
        "label": "Annotation"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "submenu": "jungleKit.submenu",
          "group": "z_jungleKit",
          "when": "editorTextFocus"
        }
      ],
      "jungleKit.submenu": [
        {
          "command": "jungleKit.addTodo",
          "group": "tag@1"
        },
        {
          "command": "jungleKit.addBookmark",
          "group": "tag@2"
        },
        {
          "command": "jungleKit.addReviewPoint",
          "group": "tag@3"
        },
        {
          "command": "jungleKit.addWarning",
          "group": "tag@4"
        },
        {
          "command": "jungleKit.addBreakpoint",
          "group": "tag@5"
        }
      ],
      "scm/title": [
        {
          "command": "jungleKit.generateCommitMessage",
          "group": "navigation",
          "when": "scmProvider == git"
        }
      ],
      "view/title": [
        {
          "command": "jungleKit.addTagAtCursor",
          "when": "view == jungleKit.tags",
          "group": "navigation@1"
        },
        {
          "command": "jungleKit.searchTags",
          "when": "view == jungleKit.tags",
          "group": "navigation@2"
        },
        {
          "command": "jungleKit.refreshTags",
          "when": "view == jungleKit.tags",
          "group": "navigation@3"
        },
        {
          "command": "jungleKit.toggleTagView",
          "when": "view == jungleKit.tags",
          "group": "navigation@4"
        },
        {
          "command": "jungleKit.clearAllTags",
          "when": "view == jungleKit.tags",
          "group": "navigation@5"
        },
        {
          "command": "jungleKit.collapseTags",
          "when": "view == jungleKit.tags",
          "group": "navigation@6"
        },
        {
          "command": "jungleKit.createPR",
          "when": "view == jungleKit.tags",
          "group": "actions@1"
        },
        {
          "command": "jungleKit.showGoal",
          "when": "view == jungleKit.tags",
          "group": "actions@1.5"
        },
        {
          "command": "jungleKit.generateCommitMessage",
          "when": "view == jungleKit.tags",
          "group": "actions@2"
        },
        {
          "command": "jungleKit.pullAndPush",
          "when": "view == jungleKit.tags",
          "group": "actions@4"
        },
        {
          "command": "jungleKit.checkReviews",
          "when": "view == jungleKit.tags",
          "group": "actions@3"
        },
        {
          "command": "jungleKit.configureShortcuts",
          "when": "view == jungleKit.tags",
          "group": "settings@1"
        }
      ],
      "view/item/context": [
        {
          "command": "jungleKit.editTag",
          "when": "viewItem =~ /^tag-|^tagRegion-/",
          "group": "inline@1"
        },
        {
          "command": "jungleKit.resolveTagInline",
          "when": "viewItem =~ /^tag-|^tagRegion-/",
          "group": "inline@2"
        },
        {
          "command": "jungleKit.clearFileTags",
          "when": "viewItem =~ /^tagFile-/",
          "group": "inline"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts",
    "test": "npm run compile && node ./scripts/smoke-test.js && node ./scripts/unit-test.js",
    "package": "vsce package",
    "publish": "vsce publish"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.56.0",
    "typescript": "^5.3.0",
    "@vscode/vsce": "^2.22.0"
  },
  "dependencies": {
    "openai": "^4.20.0",
    "clang-format": "^1.8.0"
  }
}
